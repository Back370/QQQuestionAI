# このファイルを backend/.env にコピーして値を埋める。
#   cp env.example .env
# .env は .gitignore 済みでコミットされない。実際のキーをこの env.example に書かないこと。

# Gemini API キー（必須。https://aistudio.google.com/apikey で発行）
GOOGLE_API_KEY=your-gemini-api-key-here

# 使用モデル（省略時 gemini-2.5-flash。古いモデルは無料枠が無い場合がある）
# QQQ_MODEL=gemini-2.5-flash

# Web検索用 Tavily API キー（任意。無ければ DuckDuckGo にフォールバック）
# TAVILY_API_KEY=your-tavily-api-key-here

# サーバのポート（省略時 8756）
# QQQ_PORT=8756

# APIキーなしで全フローを試すデモモード
# QQQ_FAKE_LLM=1
