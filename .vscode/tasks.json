{
  "version": "2.0.0",
  "tasks": [
    {
      // launch.json の preLaunchTask から呼ばれる。拡張は extension/ 配下にあるため
      // cwd を移して npm run compile（バックエンドの同梱 + tsc）を実行する。
      "label": "compile-extension",
      "type": "shell",
      "command": "npm run compile",
      "options": {
        "cwd": "${workspaceFolder}/extension"
      },
      "group": "build",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    }
  ]
}
